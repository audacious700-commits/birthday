</html>*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  font-family:'Poppins',sans-serif;
  background:#fff7fb;
  color:#333;
  overflow-x:hidden;
}

/* DARK MODE */
body.dark{
  background:#121212;
  color:white;
}

/* HERO */

.hero{
  position:relative;
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  overflow:hidden;
}

.hero-bg{
  position:absolute;
  width:100%;
  height:100%;
  object-fit:cover;
  filter:blur(4px) brightness(0.7);
}

.overlay{
  position:absolute;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.2);
}

.hero-content{
  position:relative;
  z-index:2;
  text-align:center;
  padding:30px;
}

.hero h1{
  font-size:4rem;
  color:white;
  font-family:'Sacramento',cursive;
}

.hero p{
  color:white;
  margin-top:10px;
  font-size:1.2rem;
}

.glass{
  background:rgba(255,255,255,0.15);
  backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,0.2);
  border-radius:25px;
  box-shadow:0 8px 32px rgba(0,0,0,0.1);
}

/* BUTTON */

.btn{
  display:inline-block;
  margin-top:25px;
  padding:14px 28px;
  border-radius:40px;
  text-decoration:none;
  background:linear-gradient(45deg,#ff7eb3,#ff758c);
  color:white;
  font-weight:600;
  transition:0.3s;
}

.btn:hover{
  transform:scale(1.05);
}

/* GALLERY */

.gallery-section{
  padding:80px 20px;
  text-align:center;
}

.gallery-section h2{
  margin-bottom:40px;
}

.gallery{
  columns:2 250px;
  gap:15px;
}

.gallery img{
  width:100%;
  margin-bottom:15px;
  border-radius:20px;
  cursor:pointer;
  transition:0.4s;
}

.gallery img:hover{
  transform:scale(1.03);
}

/* LIGHTBOX */

.lightbox{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.9);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:1000;
}

.lightbox img{
  max-width:90%;
  max-height:90%;
  border-radius:20px;
}

.lightbox span{
  position:absolute;
  top:20px;
  right:30px;
  color:white;
  font-size:40px;
  cursor:pointer;
}

/* LOVE LETTER */

.love-letter{
  padding:80px 20px;
  display:flex;
  justify-content:center;
}

.paper{
  max-width:700px;
  padding:40px;
  text-align:center;
  background:#fffaf5;
}

.paper h2{
  margin-bottom:20px;
  font-family:'Sacramento',cursive;
  font-size:3rem;
}

/* TIMELINE */

.timeline-section{
  padding:80px 20px;
}

.timeline{
  border-left:3px solid pink;
  max-width:700px;
  margin:auto;
}

.timeline-item{
  margin:30px;
  padding:20px;
  background:white;
  border-radius:20px;
  box-shadow:0 5px 20px rgba(0,0,0,0.05);
}

/* REASONS */

.reasons{
  padding:80px 20px;
  text-align:center;
}

.reason-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-top:40px;
}

.reason-card{
  padding:30px;
  border-radius:20px;
  background:white;
  transition:0.4s;
  cursor:pointer;
}

.reason-card:hover{
  transform:translateY(-10px) rotate(1deg);
  background:#ffe0eb;
}

/* SURPRISE */

.surprise{
  padding:100px 20px;
  text-align:center;
}

/* MODAL */

.modal{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.7);
  justify-content:center;
  align-items:center;
  z-index:2000;
}

.modal-content{
  width:90%;
  max-width:500px;
  padding:40px;
  text-align:center;
  position:relative;
}

.modal-content span{
  position:absolute;
  top:10px;
  right:20px;
  font-size:30px;
  cursor:pointer;
}

/* FINAL */

.final-section{
  position:relative;
  padding:100px 20px;
  text-align:center;
}

.final-photo{
  width:250px;
  border-radius:30px;
  margin-bottom:30px;
}

.final-section h2{
  font-size:4rem;
  color:#ff4d88;
  font-family:'Sacramento',cursive;
}

/* MUSIC BUTTON */

.music-btn,
.theme-toggle{
  position:fixed;
  z-index:999;
  border:none;
  width:50px;
  height:50px;
  border-radius:50%;
  cursor:pointer;
  font-size:20px;
  background:white;
  box-shadow:0 4px 20px rgba(0,0,0,0.1);
}

.music-btn{
  bottom:20px;
  right:20px;
}

.theme-toggle{
  top:20px;
  right:20px;
}

/* FLOATING HEARTS */

.hearts::before,
.hearts::after{
  content:"❤️ ❤️ ❤️";
  position:fixed;
  animation:float 10s linear infinite;
  opacity:0.2;
  font-size:30px;
}

@keyframes float{
  from{
    transform:translateY(100vh);
  }
  to{
    transform:translateY(-100vh);
  }
}

/* MOBILE */

@media(max-width:768px){

  .hero h1{
    font-size:2.8rem;
  }

  .paper{
    padding:25px;
  }

  .final-section h2{
    font-size:3rem;
  }
